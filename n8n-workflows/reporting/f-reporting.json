    {
      "parameters": {
        "jsCode": "// Compose pre-formatted report body from all upstream metric nodes.\n// Uses nullish coalescing so a failed query shows '— unavailable —'.\n\nconst na = '\\u2014 unavailable \\u2014';\n\nconst weekLabel = $('Compute Date Range').first()?.json?.weekLabel ?? na;\n\n// Twenty metrics\nconst newCandidates    = $('Query Twenty Candidates').first()?.json?.data?.findManyCandidates?.totalCount ?? na;\nconst appsBlue         = $('Query Twenty Applications').first()?.json?.data?.blueCollar?.totalCount ?? na;\nconst appsWhite        = $('Query Twenty Applications').first()?.json?.data?.whiteCollar?.totalCount ?? na;\nconst interviewsSched  = $('Query Twenty Interviews Scheduled').first()?.json?.data?.findManyInterviews?.totalCount ?? na;\nconst interviewsComp   = $('Query Twenty Interviews Completed').first()?.json?.data?.findManyInterviews?.totalCount ?? na;\nconst placements       = $('Query Twenty Placements').first()?.json?.data?.findManyApplications?.totalCount ?? na;\nconst reviewOpen       = $('Query Twenty ReviewTasks Open').first()?.json?.data?.findManyReviewTasks?.totalCount ?? na;\nconst reviewResolved   = $('Query Twenty ReviewTasks Resolved').first()?.json?.data?.findManyReviewTasks?.totalCount ?? na;\n\n// Bookings DB metrics\nconst screeningDone    = $('Query Screening Completions').first()?.json?.count ?? na;\nconst workflowErrors   = $('Query Workflow Errors').first()?.json?.count ?? na;\nconst voiceNoteQueue   = $('Query Voice Note Review Queue').first()?.json?.count ?? na;\nconst aiCostThisWeek   = $('Query AI Cost This Week').first()?.json?.total_usd ?? na;\nconst aiCostLastWeek   = $('Query AI Cost Last Week').first()?.json?.total_usd ?? na;\n\n// WoW AI cost delta\nlet wowDelta = na;\nif (aiCostThisWeek !== na && aiCostLastWeek !== na) {\n  const diff = Number(aiCostThisWeek) - Number(aiCostLastWeek);\n  const sign = diff >= 0 ? '+' : '';\n  wowDelta = sign + diff.toFixed(4) + ' USD';\n}\n\n// Calibration block (only if the env var was active AND queries ran)\nconst calibrationActive = $env.CALIBRATION_WINDOW_ACTIVE === 'true';\nlet calibrationSection = '';\nif (calibrationActive) {\n  const agreePct     = $('Query Calibration AI Agreement').first()?.json?.agree_pct ?? na;\n  const humanDecisions = $('Query Calibration Human Decisions').first()?.json?.human_decisions ?? na;\n  if (agreePct !== na || humanDecisions !== na) {\n    calibrationSection = `\nCalibration (week 1-2 window):\n  AI vs human agreement: ${agreePct !== na ? agreePct + '%' : na}\n  Human review decisions: ${humanDecisions}`;\n  }\n}\n\nconst reportText = `Weekly HR Report — ${weekLabel}\n\nPipeline:\n  New candidates:        ${newCandidates}\n  New applications:      Blue-collar ${appsBlue}  White-collar ${appsWhite}\n  Screened this week:    ${screeningDone}\n  Interviews scheduled:  ${interviewsSched}\n  Interviews completed:  ${interviewsComp}\n  Placements:            ${placements}\n\nReview queue:\n  Tasks opened:          ${reviewOpen}\n  Tasks resolved:        ${reviewResolved}\n  Voice notes for human: ${voiceNoteQueue}\n\nSystem health:\n  Workflow errors:       ${workflowErrors}\n  AI cost this week:     ${aiCostThisWeek !== na ? aiCostThisWeek + ' USD' : na}\n  AI cost last week:     ${aiCostLastWeek !== na ? aiCostLastWeek + ' USD' : na}\n  WoW delta:             ${wowDelta}${calibrationSection}`;\n\nreturn [{ json: { reportText } }];"
      },
