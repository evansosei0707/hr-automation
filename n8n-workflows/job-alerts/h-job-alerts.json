    {
      "id": "h0000019-0019-0019-0019-000000000019",
      "name": "Update Anti-Spam State",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [4600, 200],
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "PLACEHOLDER_POSTGRES",
          "name": "Bookings DB (n8n_bookings)"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO candidate_facts (candidate_id, facts)\nVALUES ($1, jsonb_build_object('last_reengaged_at', $2::text, 'reengagement_count_ytd', $3::int))\nON CONFLICT (candidate_id) DO UPDATE\n  SET facts = candidate_facts.facts\n    || jsonb_build_object('last_reengaged_at', $2::text, 'reengagement_count_ytd', $3::int),\n    updated_at = NOW()",
        "options": {
          "queryReplacement": "={{ [\n  $('SplitInBatches — Candidates').first()?.json?.candidate?.id ?? '00000000-0000-0000-0000-000000000000',\n  new Date().toISOString(),\n  (() => {\n    const prevCount = parseInt($('Read Anti-Spam State').first()?.json?.reengagement_count_ytd ?? '0', 10);\n    const prevDate = $('Read Anti-Spam State').first()?.json?.last_reengaged_at;\n    const currentYear = $('Compute Scan Window').first()?.json?.currentYear;\n    const prevYear = prevDate ? new Date(prevDate).getFullYear() : 0;\n    return prevYear < currentYear ? 1 : prevCount + 1;\n  })()\n] }}"
        }
      }
    },
    {
      "id": "h0000020-0020-0020-0020-000000000020",
      "name": "Mark Posting Processed",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [4860, 200],
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "PLACEHOLDER_POSTGRES",
          "name": "Bookings DB (n8n_bookings)"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO candidate_facts (candidate_id, facts)\nVALUES ('system-h-dedup', jsonb_build_object('h_processed_postings', jsonb_build_array($1::text)))\nON CONFLICT (candidate_id) DO UPDATE\n  SET facts = jsonb_set(\n    candidate_facts.facts,\n    '{h_processed_postings}',\n    COALESCE(candidate_facts.facts->'h_processed_postings', '[]'::jsonb) || jsonb_build_array($1::text)\n  ),\n  updated_at = NOW()",
        "options": {
          "queryReplacement": "={{ [$('SplitInBatches — Postings').first()?.json?.id ?? ''] }}"
        }
      }
    },
