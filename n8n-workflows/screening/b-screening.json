    {
      "id": "b000019-0019-b019-0019-000000000019",
      "name": "Parse Score Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3320,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const content = $('Score Against Rubric \u2014 Claude Sonnet').first()?.json?.content ?? '';\nlet scoreData = { score: 0, tier: 'WEAK', rationale: 'Score parse failed', breakdown: { skills: 0, experience: 0, education: 0 } };\ntry {\n  const match = content.match(/\\{[\\s\\S]*\\}/);\n  if (match) {\n    const parsed = JSON.parse(match[0]);\n    scoreData = {\n      score: Number(parsed.score ?? 0),\n      tier: ['STRONG','BORDERLINE','WEAK'].includes(parsed.tier) ? parsed.tier : 'WEAK',\n      rationale: String(parsed.rationale ?? '').slice(0, 200),\n      breakdown: {\n        skills: Number(parsed.breakdown?.skills ?? 0),\n        experience: Number(parsed.breakdown?.experience ?? 0),\n        education: Number(parsed.breakdown?.education ?? 0)\n      }\n    };\n  }\n} catch(e) {\n  scoreData.rationale = 'Parse error: ' + String(e.message).slice(0, 100);\n}\nreturn [{ json: scoreData }];"
      }
    },
