    {
      "parameters": {
        "jsCode": "// Compute date range: last week Mon 00:00 to Sun 23:59:59 Africa/Accra.\n// n8n Code node has Date as a global — no require() needed.\n// Africa/Accra is UTC+0 (no DST), so UTC == local time.\n\nconst now = new Date();\n\n// Day of week: 0=Sun, 1=Mon ... 6=Sat\nconst todayDow = now.getUTCDay();\n\n// Days since last Monday (the START of CURRENT week)\n// If today is Monday (1), daysToCurrentMon = 0; Sun (0) = 6; Sat (6) = 5 etc.\nconst daysToCurrentMon = (todayDow === 0) ? 6 : (todayDow - 1);\n\n// Last week Monday = current week Monday - 7 days\nconst weekStart = new Date(now);\nweekStart.setUTCDate(now.getUTCDate() - daysToCurrentMon - 7);\nweekStart.setUTCHours(0, 0, 0, 0);\n\n// Last week Sunday = current week Monday - 1 day end of day\nconst weekEnd = new Date(now);\nweekEnd.setUTCDate(now.getUTCDate() - daysToCurrentMon - 1);\nweekEnd.setUTCHours(23, 59, 59, 999);\n\n// Prior week (for WoW delta on AI cost)\nconst priorWeekStart = new Date(weekStart);\npriorWeekStart.setUTCDate(weekStart.getUTCDate() - 7);\n\nconst priorWeekEnd = new Date(weekEnd);\npriorWeekEnd.setUTCDate(weekEnd.getUTCDate() - 7);\n\nconst toIso = (d) => d.toISOString();\n\nreturn [{\n  json: {\n    weekStartIso: toIso(weekStart),\n    weekEndIso: toIso(weekEnd),\n    priorWeekStartIso: toIso(priorWeekStart),\n    priorWeekEndIso: toIso(priorWeekEnd),\n    weekLabel: weekStart.toISOString().slice(0, 10) + ' to ' + weekEnd.toISOString().slice(0, 10)\n  }\n}];"
      },
      "id": "f0000003-0003-0003-0003-000000000003",
      "name": "Compute Date Range",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 380]
    },
