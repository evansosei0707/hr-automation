        "jsonBody": "={{ { query: '{ jobPostings(filter: { status: { eq: OPEN }, postedAt: { gte: \"' + $json.windowStart + '\" } }) { edges { node { id title category collarType } } } }' } }}",
        "options": {
          "timeout": 15000,
