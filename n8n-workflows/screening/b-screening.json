      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const content = $('Extract Structured Facts \u2014 Claude Sonnet').first()?.json?.content ?? '';\nlet facts = {};\ntry {\n  const match = content.match(/\\{[\\s\\S]*\\}/);\n  facts = match ? JSON.parse(match[0]) : {};\n} catch(e) {\n  facts = {};\n}\nconst cvText = $('Prepare CV Text').first()?.json?.cvText ?? '';\nreturn [{ json: { extractedFacts: facts, cvText } }];"
      }
