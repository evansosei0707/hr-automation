      "name": "Compute Scan Window",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        200
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const now = new Date();\nconst windowStart = new Date(now.getTime() - 5 * 60 * 1000).toISOString();\nconst sixMonthsAgo = new Date(now.getTime() - 180 * 24 * 60 * 60 * 1000).toISOString();\nconst ninetyDaysAgo = new Date(now.getTime() - 90 * 24 * 60 * 60 * 1000).toISOString();\nconst fourteenDaysAgo = new Date(now.getTime() - 14 * 24 * 60 * 60 * 1000).toISOString();\nconst currentYear = now.getFullYear();\nreturn [{ json: { windowStart, sixMonthsAgo, ninetyDaysAgo, fourteenDaysAgo, currentYear } }];\n"
      }
    },
    {
      "id": "h0000004-0004-0004-0004-000000000004",
