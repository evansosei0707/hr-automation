              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "string",
        "body": "={{ JSON.stringify({ messaging_product: 'whatsapp', to: $('WA Send Trigger').first()?.json?.to, type: 'template', template: { name: $('WA Send Trigger').first()?.json?.templateName || 'still_interested_10d', language: { code: 'en' }, components: ($('WA Send Trigger').first()?.json?.templateVars || []).length > 0 ? [{ type: 'body', parameters: ($('WA Send Trigger').first()?.json?.templateVars || []).map(v => ({ type: 'text', text: String(v) })) }] : [] } }) }}",
        "options": {
          "timeout": 20000,
          "retry": {
            "enabled": true,
