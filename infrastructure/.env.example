# =============================================
# HR Automation — environment template
# Copy to .env and fill in. Never commit .env.
# =============================================

# ---- Twenty CRM ----
TWENTY_DB_USER=twenty
TWENTY_DB_PASSWORD=changeme_twenty
TWENTY_DB_NAME=twenty
TWENTY_SERVER_URL=http://localhost:3000
TWENTY_APP_SECRET=generate_with_openssl_rand_hex_32

# ---- Bookings DB (n8n-owned) ----
BOOKINGS_DB_USER=n8n_bookings
BOOKINGS_DB_PASSWORD=changeme_bookings
BOOKINGS_DB_NAME=bookings

# ---- n8n ----
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5678
# REST API key for scripts/n8n-debug.sh and scripts/n8n-reimport.sh.
# Generate in n8n UI: Settings → n8n API → Create API key.
N8N_API_KEY=
N8N_API_URL=http://localhost:5678
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=changeme_n8n
N8N_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32
N8N_JWT_SECRET=generate_with_openssl_rand_hex_32

# ---- WhatsApp Cloud API ----
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=pick_a_random_string
WHATSAPP_WEBHOOK_URL=https://your-domain.example/webhook/whatsapp

# ---- Meta Graph (FB + IG) ----
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_IG_USER_ID=

# ---- X (Twitter) ----
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REFRESH_TOKEN=
X_USER_ID=

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@YourFirmCareers

# ---- Google ----
GOOGLE_API_KEY=
GOOGLE_SERVICE_ACCOUNT_PATH=secrets/google-sa.json
GOOGLE_HOLIDAYS_CALENDAR_ID=en.gh#holiday@group.v.calendar.google.com

# ---- Twenty CRM (programmatic access) ----
# Generate via Twenty UI: Settings → API & Webhooks → Create API key.
# Bind the key to a Role with full CRUD on our custom objects (e.g. n8n-service).
# JWT token, workspace-scoped. See ADR-0005 and reference/twenty-v2.1.0-api.md.
TWENTY_API_KEY=
TWENTY_API_BASE_URL=http://localhost:3000

# ---- Anthropic Claude ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5
ANTHROPIC_MAX_OUTPUT_SONNET=1000
ANTHROPIC_MAX_OUTPUT_HAIKU=500

# ---- Groq Whisper (transcription) ----
# Active provider per ADR-0006 (2026-04-28).
# Free-tier key: sign up at https://console.groq.com (no card required).
# OpenAI-compatible API; same wire shape as the OpenAI Transcribe section
# below (kept as historical artifact).
GROQ_API_KEY=
GROQ_TRANSCRIBE_MODEL=whisper-large-v3-turbo
GROQ_API_BASE_URL=https://api.groq.com/openai/v1

# ---- OpenAI Transcribe (HISTORICAL — superseded by Groq per ADR-0006) ----
# Kept as a reference for the voucher script `scripts/voucher/openai-transcribe.sh`,
# which remains in the repo as a "what we tried" artifact. Empty values are
# expected; do not populate unless you intentionally want to re-attempt the
# OpenAI path (billing was blocked twice from Ghana — see ADR-0006 context).
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# ---- Backblaze B2 (backups) ----
B2_BUCKET=
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=

# ---- Ops ----
ALERT_WHATSAPP_CHAT_ID=
AI_DAILY_BUDGET_USD=10
AI_WEEKLY_BUDGET_USD=50

# ---- Environment marker ----
ENVIRONMENT=local  # local | staging | production
