            "messages": "={{ [{ role: 'user', content: 'Candidate first name: ' + ($('SplitInBatches — Candidates').first()?.json?.candidate?.name?.split(' ')?.[0] ?? 'there') + '\\nPrevious role: ' + ($('SplitInBatches — Candidates').first()?.json?.jobPosting?.title ?? 'a role we had earlier') + '\\nNew role: ' + ($('SplitInBatches — Postings').first()?.json?.title ?? 'a new opening') + '\\nWrite the WhatsApp re-engagement message now.' }] }}"
