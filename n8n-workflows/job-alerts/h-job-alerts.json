      "id": "h0000010-0010-0010-0010-000000000010",
      "name": "Query Eligible Applications",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2260,
        200
      ],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "POST",
        "url": "={{ $env.TWENTY_API_URL }}/graphql",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Bearer ' + $env.TWENTY_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "jsonBody": "={{ { query: '{ applications(filter: { reEngagementEligible: { eq: true }, createdAt: { gte: \"' + $json.sixMonthsAgo + '\" } }) { edges { node { id reEngagedAt jobPosting { id title category } candidate { id name whatsappNumberE164 consentStatus lastActivityAt dataRetentionPolicy strengthTier applications { edges { node { status } } } } } } } }' } }}",
        "options": {
          "timeout": 15000,
