    {
      "id": "h0000007-0007-0007-0007-000000000007",
      "name": "Filter Unprocessed Postings",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1480, 200],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const dedupRow = $('Read Dedup State').first()?.json;\nlet processed = [];\ntry { processed = JSON.parse(dedupRow?.processed || '[]'); } catch(e) { processed = []; }\nif (!Array.isArray(processed)) processed = [];\nconst allPostings = $('Query New Open JobPostings').first()?.json?.data?.jobPostings?.edges?.map(e => e.node) ?? [];\nconst unprocessed = allPostings.filter(p => !processed.includes(p.id));\nreturn [{ json: { postings: unprocessed } }];\n"
      }
    },
