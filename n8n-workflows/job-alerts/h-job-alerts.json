      "parameters": {
        "language": "javaScript",
        "jsCode": "const last = $json.last_reengaged_at;\nconst count = parseInt($json.reengagement_count_ytd ?? '0', 10);\nconst fourteenDaysAgo = Date.now() - 14 * 24 * 60 * 60 * 1000;\nconst notRecentlyEngaged = !last || new Date(last).getTime() < fourteenDaysAgo;\nconst underYearLimit = count < 4;\nreturn [{ json: { ...$input.item.json, spamCheckOk: (notRecentlyEngaged && underYearLimit) ? 'yes' : '' } }];\n"
      }
