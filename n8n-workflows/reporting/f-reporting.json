    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  COUNT(*) FILTER (WHERE resolution = 'agree') AS agree_count,\n  COUNT(*) AS total_decisions,\n  ROUND(\n    100.0 * COUNT(*) FILTER (WHERE resolution = 'agree') / NULLIF(COUNT(*), 0),\n    1\n  ) AS agree_pct\nFROM (\n  SELECT\n    CASE\n      WHEN el.data->>'ai_score' IS NOT NULL\n       AND wt.resolvedAt IS NOT NULL\n       AND ABS((el.data->>'ai_score')::numeric - (el.data->>'human_score')::numeric) <= 1\n      THEN 'agree'\n      ELSE 'disagree'\n    END AS resolution\n  FROM event_log el\n  JOIN (\n    SELECT id, \"resolvedAt\"\n    FROM information_schema.tables\n    WHERE 1=0\n  ) wt ON false\n  WHERE el.workflow_name IN ('workflow_b_screening', 'workflow_c_screening')\n    AND el.ts >= $1\n    AND el.ts < $2\n    AND el.event = 'screening_scored'\n) sub",
        "options": {
          "queryReplacement": "={{ [$('Compute Date Range').first()?.json?.weekStartIso, $('Compute Date Range').first()?.json?.weekEndIso] }}"
        }
      },
