{
  "name": "Subflow \u2014 WA Send",
  "nodes": [
    {
      "id": "was00001-0001-0001-0001-000000000001",
      "name": "WA Send Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        200,
        300
      ],
      "parameters": {}
    },
    {
      "id": "was00002-0002-0002-0002-000000000002",
      "name": "Fetch Last Inbound Time",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        440,
        300
      ],
      "credentials": {
        "postgres": {
          "id": "9qvzHACQwY5XcPoG",
          "name": "Bookings DB (n8n_bookings)"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT COALESCE(EXTRACT(EPOCH FROM (NOW() - MAX(occurred_at))), 0) AS seconds_since_last_inbound FROM conversation_message WHERE conversation_id = $1 AND direction = 'inbound'",
        "options": {
          "queryReplacement": "={{ $json.conversationId ?? '00000000-0000-0000-0000-000000000000' }}"
        }
      }
    },
    {
      "id": "was00003-0003-0003-0003-000000000003",
      "name": "Route Free-Form vs Template",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        680,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "cond-window",
              "leftValue": "={{ $json.seconds_since_last_inbound }}",
              "rightValue": 86400,
              "operator": {
                "type": "number",
                "operation": "lt"
              }
            },
            {
              "id": "cond-no-template",
              "leftValue": "={{ $('WA Send Trigger').first()?.json?.templateName ?? '' }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "was00004-0004-0004-0004-000000000004",
      "name": "Send Free-Form Message",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        920,
        200
      ],
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v20.0/{{ $env.WHATSAPP_PHONE_NUMBER_ID }}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.WHATSAPP_ACCESS_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "string",
        "body": "={{ JSON.stringify({ messaging_product: 'whatsapp', to: $('WA Send Trigger').first()?.json?.to, type: 'text', text: { body: $('WA Send Trigger').first()?.json?.body } }) }}",
        "options": {
          "timeout": 20000,
          "retry": {
            "enabled": true,
            "maxTries": 2,
            "waitBetweenTries": 1000
          },
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "was00005-0005-0005-0005-000000000005",
      "name": "Check Error 131047",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1160,
        200
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "cond-131047",
              "leftValue": "={{ ($json.error && $json.error.code) === 131047 || ($json.errors && $json.errors[0] && $json.errors[0].code) === 131047 }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "was00006-0006-0006-0006-000000000006",
      "name": "Send Template Message",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1400,
        200
      ],
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v20.0/{{ $env.WHATSAPP_PHONE_NUMBER_ID }}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.WHATSAPP_ACCESS_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "string",
        "body": "={{ JSON.stringify({ messaging_product: 'whatsapp', to: $('WA Send Trigger').first()?.json?.to, type: 'template', template: { name: $('WA Send Trigger').first()?.json?.templateName, language: { code: 'en' }, components: ($('WA Send Trigger').first()?.json?.templateVars || []).length > 0 ? [{ type: 'body', parameters: ($('WA Send Trigger').first()?.json?.templateVars || []).map(v => ({ type: 'text', text: String(v) })) }] : [] } }) }}",
        "options": {
          "timeout": 20000,
          "retry": {
            "enabled": true,
            "maxTries": 2,
            "waitBetweenTries": 1000
          }
        }
      }
    },
