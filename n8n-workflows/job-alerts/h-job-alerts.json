          "id": "PLACEHOLDER_POSTGRES",
          "name": "Bookings DB (n8n_bookings)"
        }
      },
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO candidate_facts (twenty_candidate_id, facts)\nVALUES ($1, jsonb_build_object('last_reengaged_at', $2::text, 'reengagement_count_ytd', $3::int))\nON CONFLICT (twenty_candidate_id) DO UPDATE\n  SET facts = candidate_facts.facts\n    || jsonb_build_object('last_reengaged_at', $2::text, 'reengagement_count_ytd', $3::int),\n    updated_at = NOW()",
        "options": {
          "queryReplacement": "={{ [\n  $('Enrich Candidate Item').first()?.json?.candidateId ?? '00000000-0000-0000-0000-000000000000',\n  new Date().toISOString(),\n  (() => {\n    const prevCount = $('Enrich Candidate Item').first()?.json?.antispamCount ?? 0;\n    const prevDate = $('Enrich Candidate Item').first()?.json?.antispamLastDate;\n    const currentYear = $('Enrich Candidate Item').first()?.json?.currentYear ?? new Date().getFullYear();\n    const prevYear = prevDate ? new Date(prevDate).getFullYear() : 0;\n    return prevYear < currentYear ? 1 : prevCount + 1;\n  })()\n] }}"
        }
      }
    },
    {
